#:import MDScreen kivymd.uix.screen.MDScreen
#:import MDGridLayout kivymd.uix.gridlayout.MDGridLayout
#:import MDLabel kivymd.uix.label.MDLabel
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDButton kivymd.uix.button.MDButton
#:import MDButtonText kivymd.uix.button.MDButtonText
#:import MDIconButton kivymd.uix.button.MDIconButton
#:import MDFabButton kivymd.uix.button.MDFabButton

#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp

# Import local components
#:import MyMDDivider screens.divider.MyMDDivider

<TempSpinWait>:
    id: temp_spin
    orientation: 'horizontal'
    adaptive_height: True
    padding: dp(8)

    MDLabel:
        text: root.txt
        font_style: "Body"
        role: "large"
        adaptive_width: True
        theme_text_color: "Custom"
        text_color: "black"
        theme_font_size: "Custom"
        font_size: sp(20)

    MDCircularProgressIndicator:
        size_hint: None, None
        size: dp(20), dp(20)
        active: True

<BatchStopBtn>:
    orientation: 'horizontal'
    spacing: dp(4)
    adaptive_height: True
    MDFabButton:
        icon: 'stop'
        style: 'small'
        theme_icon_color: "Custom"
        md_bg_color: '#e9dff7'
        icon_color: '#211c29'
        on_release: app.stop_batch()

<VideoActionBtn>:
    orientation: 'horizontal'
    spacing: dp(4)
    adaptive_height: True
    MDFabButton:
        icon: 'download'
        style: 'small'
        theme_icon_color: "Custom"
        md_bg_color: '#e9dff7'
        icon_color: '#211c29'
        on_release: app.open_vid_file_manager()
    MDFabButton:
        icon: 'delete'
        style: 'small'
        theme_icon_color: "Custom"
        md_bg_color: '#e9dff7'
        icon_color: '#211c29'
        on_release: app.current_delete_alert()

<BatchImgFolderBtn>:
    id: btn_img_fldr
    style: "filled"
    pos_hint: {"center_x": .5, "center_y": .5}
    on_release: app.open_img_fldr_manager()
    MDButtonIcon:
        icon: "folder"
    MDButtonText:
        text: "Batch"

<PreferencesPop>: # MDScrollView
    id: pop_preference
    size_hint: (1, None)
    height: dp(300)
    MDList:
        adaptive_height: True
        MDListItem:
            on_release: app.preference_toggle(self, "end_colour")
            MDListItemLeadingIcon:
                id: end_colour
                icon: root.end_colour_icon
                theme_icon_color: "Custom"
                icon_color: root.end_colour_icon_colour
            MDListItemHeadlineText:
                text: "End Colour"
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(20)
        MDListItem:
            on_release: app.preference_toggle(self, "draw_hand")
            MDListItemLeadingIcon:
                id: draw_hand
                icon: root.draw_hand_icon
                theme_icon_color: "Custom"
                icon_color: root.draw_hand_icon_colour
            MDListItemHeadlineText:
                text: "Hand on Video"
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(20)
        MDListItem:
            on_release: app.preference_toggle(self, "max_1080p")
            MDListItemLeadingIcon:
                id: max_1080p
                icon: root.max_1080p_icon
                theme_icon_color: "Custom"
                icon_color: root.max_1080p_icon_colour
            MDListItemHeadlineText:
                text: "1080p Max Resolution"
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(20)


### The kivymd main screen ###
MDScreen:
    md_bg_color: (1, 1, 1, 1)

    MDBoxLayout: # main container
        orientation: 'vertical'
        spacing: dp(4)

        MDTopAppBar:
            md_bg_color: '#7643a8'
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "menu"
                    on_release: app.menu_bar_callback(self)
            MDTopAppBarTitle:
                text: "Image2Sketch Animation"
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(22)

        MDGridLayout: # top file browser
            id: file_choose_grid
            cols: 4
            size_hint_y: 0.1
            spacing: dp(4)
            padding: 8, 10, 8, 10 # left, top, right, bottom

            MDLabel:
                id: img_selector_lbl
                text: "Select an image file >"
                size_hint_y: None
                height: self.texture_size[1]
                size_hint_x: 0.7
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(45)

            MDButton:
                id: btn_img_upload
                style: "filled"
                pos_hint: {"center_x": .5, "center_y": .5}
                on_release: app.open_img_file_manager()
                MDButtonIcon:
                    icon: "file-image"
                MDButtonText:
                    text: "Upload"
                    theme_text_color: "Custom"
                    text_color: "black"
                    theme_font_size: "Custom"
                    font_size: sp(20)

        MyMDDivider:
            color: (0, 0, 0, 0.25)

        MDGridLayout: # video player
            id: player_box
            cols: 1
            size_hint_y: 0.5
            padding: 2, 10, 2, 10 # left, top, right, bottom
            spacing: dp(4)

            # video player will be added under this box from main program

        MyMDDivider:
            color: (0, 0, 0, 0.25)

        MDGridLayout: # params
            cols: 5
            size_hint_y: 0.2
            spacing: dp(4)
            padding: 2, 10, 2, 10 # left, top, right, bottom

            # hint texts in first row
            MDLabel:
                text: "Select video speed"
                font_style: 'Body'
                role: 'large'
                size_hint_y: None
                height: self.texture_size[1]
                size_hint_x: 0.2
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(45)

            MDLabel:
                text: "Frame rate"
                font_style: 'Body'
                role: 'large'
                size_hint_y: None
                height: self.texture_size[1]
                size_hint_x: 0.2
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(45)

            MDLabel:
                text: "Object skip rate"
                font_style: 'Body'
                role: 'large'
                size_hint_y: None
                height: self.texture_size[1]
                size_hint_x: 0.2
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(45)

            MDLabel:
                text: "Background skip rate"
                font_style: 'Body'
                role: 'large'
                size_hint_y: None
                height: self.texture_size[1]
                size_hint_x: 0.2
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(45)

            MDLabel:
                text: "End image duration"
                font_style: 'Body'
                role: 'large'
                size_hint_y: None
                height: self.texture_size[1]
                size_hint_x: 0.2
                theme_text_color: "Custom"
                text_color: "black"
                theme_font_size: "Custom"
                font_size: sp(45)

            # taking the values in next row
            MDDropDownItem:
                id: split_len_drp
                on_release: app.split_len_options.open()
                size_hint_x: 0.2
                MDDropDownItemText:
                    text: "speed"
                    theme_text_color: "Custom"
                    text_color: "black"
                    theme_font_size: "Custom"
                    font_size: sp(20)

            MDTextField:
                id: frame_rate
                text: "25"
                input_filter: 'int'
                max_text_length: 2
                hint_text: "fps"
                helper_text: "default: 25"
                helper_text_mode: "persistent"
                mode: "outlined"
                size_hint_x: 0.2
                font_size: sp(45)

            MDTextField:
                id: obj_skip_rate
                text: "8"
                input_filter: 'int'
                max_text_length: 2
                hint_text: "obj skip"
                helper_text: "default: 8"
                helper_text_mode: "persistent"
                mode: "outlined"
                size_hint_x: 0.2
                font_size: sp(45)

            MDTextField:
                id: bck_skip_rate
                text: "14"
                input_filter: 'int'
                max_text_length: 2
                hint_text: "bck skip"
                helper_text: "default: 14"
                helper_text_mode: "persistent"
                mode: "outlined"
                size_hint_x: 0.2
                font_size: sp(45)

            MDTextField:
                id: main_img_duration
                text: "2"
                input_filter: 'int'
                max_text_length: 1
                hint_text: "seconds"
                helper_text: "default: 2"
                helper_text_mode: "persistent"
                mode: "outlined"
                size_hint_x: 0.2
                font_size: sp(45)

        MDGridLayout: # buttons
            cols: 3
            size_hint_y: 0.2
            spacing: dp(4)
            padding: 14, 0, 14, 0 # left, top, right, bottom

            MDIconButton:
                id: btn_end_img
                icon: "tune-variant"
                theme_icon_color: "Custom"
                icon_color: "blue"
                icon_size: sp(18)
                md_bg_color: 'gray'
                pos_hint: {"center_x": .5, "center_y": .5}
                size_hint_x: 0.2
                on_release: app.popup_preference()

            MDButton:
                id: btn_submit
                style: "filled"
                md_bg_color: 'orange'
                pos_hint: {"center_x": .5, "center_y": .5}
                size_hint_x: 0.5
                on_release: app.submit_sketch_req()
                MDButtonIcon:
                    icon: "send"
                MDButtonText:
                    text: "Submit"
                    theme_text_color: "Custom"
                    text_color: "black"
                    theme_font_size: "Custom"
                    font_size: sp(20)

            MDButton:
                id: btn_reset
                style: "filled"
                md_bg_color: '#333036'
                pos_hint: {"center_x": .5, "center_y": .5}
                size_hint_x: 0.3
                on_release: app.reset_all()
                MDButtonIcon:
                    icon: "undo-variant"
                MDButtonText:
                    text: "Reset"
                    theme_text_color: "Custom"
                    text_color: "black"
                    theme_font_size: "Custom"
                    font_size: sp(20)
